# ─────────────────────────────────────────────────────────────────
# Prompt Guidance Tool — Environment Configuration
# Copy this file to .env and fill in what you need.
# ─────────────────────────────────────────────────────────────────

# ── LLM Provider ──────────────────────────────────────────────────
# Options: ollama | openai | anthropic | mistral
LLM_PROVIDER=ollama

# ── Embedding Provider ────────────────────────────────────────────
# Options: ollama | openai | sentence-transformers
EMBED_PROVIDER=ollama

# ── Ollama (local) ────────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_LLM_MODEL=llama3.2
OLLAMA_EMBED_MODEL=nomic-embed-text
# nomic-embed-text = 768 dims  |  mxbai-embed-large = 1024
EMBED_DIMENSIONS=768

# ── OpenAI ────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_LLM_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small
# text-embedding-3-small = 1536 dims

# ── Anthropic / Claude ────────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# ── Mistral ───────────────────────────────────────────────────────
MISTRAL_API_KEY=
MISTRAL_LLM_MODEL=mistral-small-latest
MISTRAL_EMBED_MODEL=mistral-embed
# mistral-embed = 1024 dims

# ── Sentence Transformers (fully local, no API key) ───────────────
ST_MODEL=all-MiniLM-L6-v2
# all-MiniLM-L6-v2 = 384 dims

# ── Qdrant ────────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=          # leave empty for local; set for Qdrant Cloud
QDRANT_COLLECTION=prompt_knowledge

# ── RAG / Chunking ────────────────────────────────────────────────
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K=5
